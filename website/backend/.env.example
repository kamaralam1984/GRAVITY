# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL=sqlite:///./gravity.db
# PostgreSQL (production example)
# DATABASE_URL=postgresql://user:password@localhost:5432/gravity

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3020,http://localhost:3000

# ── AI / Anthropic ────────────────────────────────────────────────────────────
# Required for /ai/* endpoints (AI assistant, smart alerts)
ANTHROPIC_API_KEY=sk-ant-...

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_tXD8cP6NSHvKbR
RAZORPAY_KEY_SECRET=821t4QzCufDon3Kda3Bsu01u
RAZORPAY_WEBHOOK_SECRET=whsec_razorpay_xxxxxxxxxxxx

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_stripe_xxxxxxxxxxxx

# ── Maps & Geocoding ──────────────────────────────────────────────────────────
# Mapbox — free 50k map loads/mo → https://mapbox.com
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoieW91cnVzZXIiLCJhIjoiY...
# OpenCage — free 2500 geocoding/day → https://opencagedata.com
OPENCAGE_API_KEY=your_opencage_key_here
# Google Maps — free $200 credit/mo → https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Weather ───────────────────────────────────────────────────────────────────
# OpenWeatherMap — free 1000 calls/day → https://openweathermap.org/api
OPENWEATHER_API_KEY=your_owm_key_here
# Open-Meteo is free with NO key — use directly: https://api.open-meteo.com

# ── Push Notifications ────────────────────────────────────────────────────────
# Firebase FCM — free forever → https://console.firebase.google.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# OneSignal — free unlimited web push → https://onesignal.com
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_REST_API_KEY=your_onesignal_rest_key

# ── Email ─────────────────────────────────────────────────────────────────────
# Resend — free 3000 emails/mo → https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
# Brevo — free 300 emails/day → https://brevo.com
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx

# ── SMS India ─────────────────────────────────────────────────────────────────
# Fast2SMS — free credits on signup → https://fast2sms.com
FAST2SMS_API_KEY=your_fast2sms_key
# MSG91 — OTP + alerts India → https://msg91.com
MSG91_API_KEY=your_msg91_key
MSG91_SENDER_ID=GRAVTY

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Google Gemini — free 15 req/min, 1M tokens/day → https://aistudio.google.com
GOOGLE_GEMINI_API_KEY=AIzaSy...
# Groq — free fast inference → https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# ── Error Tracking ────────────────────────────────────────────────────────────
# Sentry — free 5k errors/mo → https://sentry.io
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
